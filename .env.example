# FORGE environment variables
# Copy to .env and fill in values before running scripts/fetch-fixtures.sh

# PurpleAir API key — required to fetch purpleair-sf-bay.json
# Get one at: https://develop.purpleair.com
PURPLEAIR_API_KEY=your_purpleair_api_key_here

# AirNow API key — required to fetch airnow-sf-bay.json
# Get one at: https://docs.airnowapi.org/account/request/
AIRNOW_API_KEY=your_airnow_api_key_here
